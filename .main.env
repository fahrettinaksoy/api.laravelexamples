APP_NAME="Laravel Examples"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.laravelexamples.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=stackvo-mysql
DB_PORT=3306
DB_DATABASE=laravelexamples
DB_USERNAME=root
DB_PASSWORD=root

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=stackvo-redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=stackvo-redis
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Telescope
TELESCOPE_ENABLED=false

# Horizon
HORIZON_NAME=laravelexamples-production

# Pulse
PULSE_ENABLED=true
PULSE_SERVER_NAME=prod-server-1
PULSE_INGEST_DRIVER=redis
PULSE_REDIS_CONNECTION=default
PULSE_SLOW_QUERIES_THRESHOLD=500

# Reverb
REVERB_APP_ID=994687
REVERB_APP_KEY=vt7yh7saawicfy8xpr2t
REVERB_APP_SECRET=hvlt9eqimatc27c2p2rs
REVERB_HOST=api.laravelexamples.com
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SCALING_ENABLED=true
REVERB_ALLOWED_ORIGINS=api.laravelexamples.com

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
